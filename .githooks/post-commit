#!/usr/bin/env bash
# Auto-bump version after feat: and fix: commits.
#
# feat: → minor bump (new commands/flags/behavior)
# fix:  → patch bump (bug fixes only)
#
# Skips version bump commits to avoid infinite loops.

set -euo pipefail

MSG=$(git log -1 --pretty=%s HEAD)

# Skip if this is already a version bump commit
if [[ "$MSG" == "chore: bump version"* ]]; then
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Store regexes in variables — bash [[ =~ ]] requires this for patterns with ()
feat_re='^feat(\([^)]+\))?:'
fix_re='^fix(\([^)]+\))?:'

if [[ "$MSG" =~ $feat_re ]]; then
  "$REPO_ROOT/scripts/bump-version.sh" minor
elif [[ "$MSG" =~ $fix_re ]]; then
  "$REPO_ROOT/scripts/bump-version.sh" patch
fi
